{
  "crons": [
    {
      "path": "/api/meet-results/cron",
      "schedule": "0 6 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/apex-athlete",
      "destination": "/apex-athlete/coach",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/apex-athlete/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=0, must-revalidate"
        }
      ]
    }
  ]
}
