{
  "name": "ramiche-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node -e \"const fs=require('fs');let s=fs.readFileSync('public/sw.js','utf8');s=s.replace(/const CACHE_VERSION = \\\"\\d+\\\"/,'const CACHE_VERSION = \\\"'+Date.now()+'\\\"');fs.writeFileSync('public/sw.js',s)\"",
    "build": "next build",
    "postbuild": "node -e \"const fs=require('fs');let s=fs.readFileSync('public/sw.js','utf8');s=s.replace(/const CACHE_VERSION = \\\"\\d+\\\"/,'const CACHE_VERSION = \\\"1740960000000\\\"');fs.writeFileSync('public/sw.js',s)\"",
    "start": "next start",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@flags-sdk/vercel": "^1.3.0",
    "@sentry/nextjs": "^10.53.1",
    "@supabase/supabase-js": "^2.99.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "firebase": "^12.9.0",
    "firebase-admin": "^13.6.1",
    "flags": "^4.0.6",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.577.0",
    "mqtt": "^5.15.1",
    "next": "^16.2.4",
    "nodemailer": "^8.0.5",
    "page-agent": "^1.5.7",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "stripe": "^20.3.1",
    "tailwindcss": "^4.1.18",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.2.7",
    "playwright": "^1.58.2",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "protobufjs": "^7.5.5",
    "node-forge": "^1.4.0",
    "fast-xml-parser": "^5.7.0",
    "fast-xml-builder": "^1.1.7",
    "flatted": "^3.4.2",
    "vite": "^7.3.2",
    "picomatch": "^4.0.4",
    "brace-expansion": "^2.0.3",
    "ip-address": "^10.1.1",
    "postcss": "^8.5.10",
    "uuid": "^11.1.1",
    "@tootallnate/once": "^3.0.1"
  }
