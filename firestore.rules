rules_version = '2';
// ════════════════════════════════════════════════════════════════════════
// PROPOSED CANONICAL Firestore ruleset — shared project apex-athlete-73755
// Drafted 2026-06-23 (Dialog-leak security pass). REVIEW, then activate with:
//     cp firestore.rules.proposed firestore.rules
// Deploy this IDENTICAL file from EVERY repo that targets apex-athlete-73755
// (mettle, ramiche-site, GALACTIK-ANTICS 2) so "last deploy wins" drift can no
// longer open a hole. Do NOT deploy until the Admin-SDK roster route is wired
// (see SECURITY-FIX-PROPOSAL.md) or coach roster sync will break.
// ════════════════════════════════════════════════════════════════════════
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Mettle / apex-athlete (youth PII) — Admin SDK only ──────────────
    match /organizations/{orgId}/{document=**} { allow read, write: if false; }
    match /subscriptions/{doc}                 { allow read, write: if false; }
    match /connectedAccounts/{doc}             { allow read, write: if false; }
    match /push_subscriptions/{id}             { allow read, write: if request.auth != null; }
    match /meet-schedules/{doc}                { allow read: if true;  allow write: if false; }
    match /meet-results/{doc}                  { allow read: if true;  allow write: if false; }

    // ── ramiche-site command center — Admin SDK only (server reads only) ─
    match /command-center/{document=**}        { allow read, write: if false; }
    match /yolo_builds/{buildId}               { allow read, write: if false; }

    // ── Galactik (consumer game / store) ────────────────────────────────
    match /users/{userId}            { allow read, write: if request.auth != null && request.auth.uid == userId; }
    match /users/{userId}/sync/{doc} { allow read, write: if request.auth != null && request.auth.uid == userId; }
    match /leaderboard/{userId}      { allow read: if true; allow write: if request.auth != null && request.auth.uid == userId; }
    match /characters/{charId}       { allow read: if true; allow write: if false; }
    match /planets/{planetId}        { allow read: if true; allow write: if false; }
    match /lore/{loreId}             { allow read: if true; allow write: if false; }
    match /commerceOrders/{sessionId}    { allow read, write: if false; }
    match /stripeWebhookEvents/{eventId} { allow read, write: if false; }

    // ── Default deny everything else (this floor is currently MISSING) ──
    match /{document=**} { allow read, write: if false; }
  }
}
