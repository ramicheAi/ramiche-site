rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Organization-scoped data ────────────────────────────
    match /organizations/{orgId}/{document=**} {
      // Allow reads from any authenticated or anonymous user
      // (app uses client-side auth via PIN, not Firebase Auth)
      // Lock down to specific origins via Firebase App Check in production
      allow read: if true;

      // Writes: only allow if the request has valid data
      // and document size is reasonable (prevent abuse)
      allow create: if request.resource.data.keys().size() < 50
                    && request.resource.size() < 1048576;
      allow update: if request.resource.data.keys().size() < 50
                    && request.resource.size() < 1048576;

      // No deletes from client — only admin SDK
      allow delete: if false;
    }

    // ── Command Center bridge data ───────────────────────────
    match /command-center/{docId} {
      allow read: if true;
      allow write: if request.resource.data.keys().size() < 100
                   && request.resource.size() < 1048576;
    }

    // ── YOLO builds (approve/reject from Command Center) ────
    match /yolo_builds/{buildId} {
      allow read: if true;
      allow write: if request.resource.data.keys().size() < 30
                   && request.resource.size() < 1048576;
    }

    // ── Everything else: deny by default ────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
